---
import '../styles/global.css';

const { frontmatter } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{frontmatter.title}</title>
</head>
<body class="font-body text-body-md bg-background selection:bg-primary-container selection:text-on-primary-container text-on-surface">
  <main class="min-h-screen pt-stack-md">
    <article class="max-w-max-width-article mx-auto px-margin-edge md:px-0">
      <header class="mb-stack-md">
        <div class="font-mono text-label-caps text-on-surface-variant mb-gutter uppercase">
          {formattedDate} {frontmatter.category ? `— ${frontmatter.category}` : ''}
        </div>
        <h1 class="font-display text-display-lg-mobile md:text-display-lg text-primary mb-stack-md">
          {frontmatter.title}
        </h1>
        <div class="custom-divider w-24"></div>
      </header>
      <section class="article-content font-body text-body-lg text-on-surface">
        <slot />
      </section>
    </article>
  </main>
</body>
</html>
