---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout 
  title={frontmatter.title}
  bodyClass="font-body text-body-md bg-background selection:bg-primary-container selection:text-on-primary-container text-on-surface overflow-y-auto overflow-x-hidden min-h-screen"
>
  <!-- Reading Progress Bar -->
  <div class="fixed top-0 left-0 w-full h-[2px] bg-white/5 z-50 pointer-events-none" aria-hidden="true">
    <div id="reading-progress" class="h-full bg-white w-0 transition-all duration-75 ease-out"></div>
  </div>

  <main class="min-h-screen pt-12 md:pt-16 pb-24">
    <article class="max-w-max-width-article mx-auto px-margin-edge md:px-0">
      <header class="mb-stack-md">
        <div class="mb-8">
          <a href="/" class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-zinc-500 hover:text-white transition-colors duration-200">
            <i class="fa-solid fa-arrow-left-long transition-transform group-hover:-translate-x-1" aria-hidden="true"></i>
            Back to Home
          </a>
        </div>
        <div class="font-mono text-label-caps text-on-surface-variant mb-gutter uppercase">
          {formattedDate} {frontmatter.category ? `— ${frontmatter.category}` : ''}
        </div>
        <h1 class="font-display text-display-lg-mobile md:text-display-lg text-primary mb-stack-md">
          {frontmatter.title}
        </h1>
        <div class="custom-divider w-24"></div>
      </header>
      <section class="article-content font-body text-body-lg text-on-surface">
        <slot />
      </section>
    </article>
  </main>

  <script>
    const progress = document.getElementById('reading-progress');
    if (progress) {
      window.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progress.style.width = `${scrollPercent}%`;
      });
    }
  </script>
</Layout>
