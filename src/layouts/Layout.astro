---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	bodyClass?: string;
	showAsciiBg?: boolean;
}

const {
	title,
	description = "Akkshay - CS & Math student at Purdue focused on RL, Multimodal Systems, and Distributed Inference.",
	bodyClass = "",
	showAsciiBg = true
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,400&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">

		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
	</head>
	<body class={bodyClass}>
		{showAsciiBg && <pre class="ascii-bg" id="ascii-bg" aria-hidden="true"></pre>}

		<div class="page">
			<slot />
		</div>

		{showAsciiBg && (
			<script>
				(function () {
					const CONFIG = {
						opacity: 0.5,   // 0–1, overall visibility of the pattern
						density: 2,      // 1–10, how much of the field fills with characters
						driftSpeed: 3,   // 0–10, how fast the pattern slowly scrolls through noise space
					};

					const host = document.getElementById('ascii-bg');
					if (!host) return;
					host.style.opacity = String(CONFIG.opacity);

					const ramp = [' ', ' ', ' ', '.', '\u00b7', ':', ';', '+', '=', '#'];
					let t = 0;

					function hash(x: number, y: number): number {
						const n = Math.sin(x * 127.1 + y * 311.7) * 43758.5453;
						return n - Math.floor(n);
					}
					function vnoise(x: number, y: number): number {
						const xi = Math.floor(x), yi = Math.floor(y), xf = x - xi, yf = y - yi;
						const tl = hash(xi, yi), tr = hash(xi + 1, yi), bl = hash(xi, yi + 1), br = hash(xi + 1, yi + 1);
						const u = xf * xf * (3 - 2 * xf), v = yf * yf * (3 - 2 * yf);
						return tl * (1 - u) * (1 - v) + tr * u * (1 - v) + bl * (1 - u) * v + br * u * v;
					}
					function fbm(x: number, y: number): number {
						let s = 0, a = 0.5, f = 1;
						for (let i = 0; i < 4; i++) { s += a * vnoise(x * f, y * f); f *= 2; a *= 0.55; }
						return s / 0.92;
					}

					let cachedMetrics: { cw: number; lh: number } | null = null;
					function metrics() {
						if (cachedMetrics) return cachedMetrics;
						const s = document.createElement('span');
						s.style.cssText = 'position:absolute;visibility:hidden;white-space:pre;font:inherit;letter-spacing:inherit';
						s.textContent = new Array(101).join('0');
						host.appendChild(s);
						const cw = s.getBoundingClientRect().width / 100;
						s.remove();
						const lh = parseFloat(getComputedStyle(host).lineHeight) || 15;
						cachedMetrics = { cw: cw || 9, lh: lh };
						return cachedMetrics;
					}

					function build() {
						const m = metrics();
						const cols = Math.ceil(window.innerWidth / m.cw) + 1;
						const rows = Math.ceil(window.innerHeight / m.lh) + 1;
						let out = '';
						for (let r = 0; r < rows; r++) {
							let line = '';
							const dy = (r - rows * 0.32) / rows;
							const dy_sq = dy * dy;
							const dy2 = (r - rows * 0.82) / rows;
							const dy2_sq = dy2 * dy2;

							for (let c = 0; c < cols; c++) {
								const n = fbm(c * 0.045 + t * 0.01, r * 0.072 + t * 0.04);
								const dx = (c - cols * 0.74) / cols;
								const blob = Math.exp(-(dx * dx + dy_sq) * 7) * 0.55;
								const dx2 = (c - cols * 0.18) / cols;
								const blob2 = Math.exp(-(dx2 * dx2 + dy2_sq) * 10) * 0.45;
								let v = n * 0.7 + blob + blob2 - 0.16 + (CONFIG.density * 0.04 - 0.2);
								v = v < 0 ? 0 : v > 1 ? 1 : v;
								let idx = Math.floor(Math.pow(v, 1.45) * ramp.length);
								if (idx > ramp.length - 1) idx = ramp.length - 1;
								line += ramp[idx];
							}
							out += line + '\n';
						}
						host.textContent = out;
					}
					let timer: NodeJS.Timeout | string | number | undefined;
					function onResize() {
						cachedMetrics = null;
						clearTimeout(timer);
						timer = setTimeout(build, 150);
					}
					function tick() {
						if (CONFIG.driftSpeed > 0) {
							t += CONFIG.driftSpeed * 0.015;
							build();
						}
						requestAnimationFrame(tick);
					}
					build();
					tick();
					window.addEventListener('resize', onResize);
				})();
			</script>
		)}
	</body>
</html>
