---

<Layout title="akkshaysr - Portfolio">
	<main class="container">
		<div class="bento-grid">
			
			<!-- ROW 1: Connect & Bio -->
			<BentoCard span={3} class="connect-card">
				<h2 class="label-caps connect-title">Connect</h2>
				<div class="social-grid">
					{socials.map((social) => (
						<a href={social.url} aria-label={social.label} class="social-link group">
							<div class="social-icon">
								<Fragment set:html={social.svg} />
							</div>
						</a>
					))}
				</div>
			</BentoCard>

			<BentoCard span={9}>
				<h1 class="brand-title mb-4">akkshaysr</h1>
				<p class="body-lg max-w-2xl">
					Hello, I'm a designer and developer building structured, playful interfaces. I focus on creating digital environments that are both highly functional and aesthetically pleasing, blending modern minimalism with editorial design principles.
				</p>
			</BentoCard>

			<!-- ROW 2: Projects Carousel -->
			<ProjectCarousel projects={projects} />

			<!-- ROW 3: Latest Article / View All / Resume -->
			<BentoCard span={6} class="group cursor-pointer">
				<div class="flex flex-col h-full justify-between">
					<div>
						<Chip label="Latest Article" />
						<h3 class="headline-serif mt-4 group-hover:text-primary transition-colors">The Philosophy of Structured Playfulness</h3>
					</div>
					<div class="flex justify-between items-end mt-8">
						<span class="body-md text-on-surface-variant">Oct 24, 2024</span>
						<span class="material-symbols-outlined text-primary">arrow_forward</span>
					</div>
				</div>
			</BentoCard>

			<BentoCard span={3} theme="secondary" align="center" class="group cursor-pointer">
				<div class="icon-circle-outline mb-4 group-hover:scale-110 transition-transform">
					<span class="material-symbols-outlined text-3xl">article</span>
				</div>
				<h3 class="headline-serif-sm">View All Articles</h3>
			</BentoCard>

			<BentoCard span={3} theme="tertiary" align="center" class="group cursor-pointer">
				<div class="icon-circle-outline mb-4 group-hover:scale-110 transition-transform">
					<span class="material-symbols-outlined text-3xl">download</span>
				</div>
				<h3 class="headline-serif-sm">Download Resume</h3>
			</BentoCard>

		</div>
	</main>
</Layout>

<style>
	.connect-card {
		padding-top: 1.5rem;
	}

	.connect-title {
		color: #000000;
		opacity: 1;
		margin-bottom: 1.5rem;
	}

	.social-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.social-link {
		text-decoration: none;
	}

	.social-icon {
		width: 5rem;
		height: 5rem;
		background-color: var(--color-surface-container);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-inner);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s ease-in-out;
		color: #000000;
	}

	.social-link:hover .social-icon {
		background-color: var(--color-surface-container-high);
		border-color: #000000;
		transform: translateY(-2px);
	}

	.social-icon svg {
		width: 1.375rem;
		height: 1.375rem;
	}

	.brand-title {
		font-family: var(--font-headline);
		font-size: 4rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.1;
		color: var(--color-primary);
	}

	.headline-serif {
		font-family: var(--font-headline);
		font-size: 2rem;
		font-weight: 600;
		line-height: 1.3;
	}

	.headline-serif-sm {
		font-family: var(--font-headline);
		font-size: 1.5rem;
		font-weight: 600;
	}

	.icon-circle-outline {
		width: 4rem;
		height: 4rem;
		background-color: rgba(0, 0, 0, 0.2);
		border-radius: var(--radius-pill);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #ffffff;
	}

	.body-lg {
		font-size: 1.125rem;
		color: var(--color-on-surface-variant);
	}

	/* Tablet Fixes */
	@media (max-width: 1024px) {
		.bento-grid {
			grid-template-columns: repeat(6, 1fr);
		}
		.span-4 { grid-column: span 3; }
		.span-8 { grid-column: span 6; }
		.span-3 { grid-column: span 3; }
		.span-6 { grid-column: span 6; }
	}

	@media (max-width: 768px) {
		.bento-grid {
			grid-template-columns: 1fr;
		}
		.brand-title {
			font-size: 2.5rem;
		}
	}
</style>