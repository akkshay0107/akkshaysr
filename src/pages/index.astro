---
import Layout from '../layouts/Layout.astro';
import BentoCard from '../components/BentoCard.astro';
import Chip from '../components/Chip.astro';
import ProjectCarousel from '../components/ProjectCarousel.astro';

const projects = [
	{ 
		title: "BentoGrid System", 
		description: "A responsive, modular CSS framework based on mathematical grid principles.",
		image: "https://lh3.googleusercontent.com/aida-public/AB6AXuB0239BgVJB_stXlbdQfYna0fnLLaVuQPMLooqB1T4XosgawaxKSR3Zb21mESQtLS-zict_tWaLBcZwvRJ6oIq9U8QAOV0GyA3o2l24MmLGVWRtcNMFJWO9V-IFGFmW7rzVo45SEOns1TD6cDOvtne4Hc8yEXXv-HnSJzdxfsj1ScZDTPQGh7_tkIgOhSwWb2a5rKm5qn5V6uoYNRSNkyif4mAPbsmaAxmlE-M7Mm12Y3yRRsBBai73du0Hc8cuuu7ZARPDhPQLNLqW"
	},
	{ 
		title: "Typeform Hybrid", 
		description: "Exploring high-contrast typography within utilitarian form structures.",
		image: "https://lh3.googleusercontent.com/aida-public/AB6AXuDBlsWZnNFRchsDAZxNibeoFa3AnUjtk_7ClzNddNNFQc5DQjqpJNYh8ntDia2kWwitB7UyAkRz8WafmP8ytMpXb-5Rt4SICeuiloVr3kosFz2-oneJeRuUh-l8v3zAdyPUH-k9TNyw7NYKEKEdnCwk6yDBE7h5hWHIUuVdpYakhcPKTzMTk6JwRkTgi_-qJq1qBhgj_BF_Ja1YeYsBqSPxNlRI9y9hQ2xWvue8mlSnhg8XDdGN7WJwLVWykSUoIDlYuesnvdBoapaK"
	},
	{ 
		title: "Minimal Analytics", 
		description: "A dashboard that reduces noise through tonal separation and thin outlines.",
		image: "https://lh3.googleusercontent.com/aida-public/AB6AXuAj-aOYgh-lc0Ib4SpqdBOzPZjxKv4X7_Rg-uha9m9F4pWVCkbzIHTW-vfl3wFZq4fOjmRxoorWXQJbsYWIv3o1qAKiZDb7umI0hLO1Idv7SVPvLrvdmvDxL8kXZZo5ZCLL88eOTcKDauJknmV_TslzB2Yq4NTwQv7ZPXlYYW20gsVYw2xiTer2OMuu-w2So9D-IkyybLaMy-40xHk9tQPHtxNBbZ-7ffWWs_VXK0dgWWxb-IKNUJOqe4DTQIPVLgX1Pr7Ddude09sD"
	}
];

const socials = [
	{ 
		label: "GitHub", 
		url: "#",
		svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>`
	},
	{ 
		label: "LinkedIn", 
		url: "#",
		svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>`
	},
	{ 
		label: "Email", 
		url: "#",
		svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>`
	}
];
---

<Layout title="akkshaysr - Portfolio">
	<main class="container">
		<div class="bento-grid">
			
			<!-- ROW 1: Connect & Bio -->
			<BentoCard span={3} theme="secondary" class="connect-card">
				<h2 class="label-caps connect-title">Connect</h2>
				<div class="social-grid">
					{socials.map((social) => (
						<a href={social.url} aria-label={social.label} class="social-link group">
							<div class="social-icon">
								<Fragment set:html={social.svg} />
							</div>
						</a>
					))}
				</div>
			</BentoCard>

			<BentoCard span={9}>
				<h1 class="brand-title mb-4">akkshaysr</h1>
				<p class="body-lg max-w-2xl">
					Hello, I'm a designer and developer building structured, playful interfaces. I focus on creating digital environments that are both highly functional and aesthetically pleasing, blending modern minimalism with editorial design principles.
				</p>
			</BentoCard>

			<!-- ROW 2: Projects Carousel -->
			<ProjectCarousel projects={projects} />

			<!-- ROW 3: Latest Article / View All / Resume -->
			<BentoCard span={6} class="group cursor-pointer">
				<div class="flex flex-col h-full justify-between">
					<div>
						<Chip label="Latest Article" />
						<h3 class="headline-serif mt-4 group-hover:text-primary transition-colors">The Philosophy of Structured Playfulness</h3>
					</div>
					<div class="flex justify-between items-end mt-8">
						<span class="body-md text-on-surface-variant">Oct 24, 2024</span>
						<span class="material-symbols-outlined text-primary">arrow_forward</span>
					</div>
				</div>
			</BentoCard>

			<BentoCard span={3} theme="secondary" align="center" class="group cursor-pointer">
				<div class="icon-circle-outline mb-4 group-hover:scale-110 transition-transform">
					<span class="material-symbols-outlined text-3xl">article</span>
				</div>
				<h3 class="headline-serif-sm">View All Articles</h3>
			</BentoCard>

			<BentoCard span={3} theme="tertiary" align="center" class="group cursor-pointer">
				<div class="icon-circle-outline mb-4 group-hover:scale-110 transition-transform">
					<span class="material-symbols-outlined text-3xl">download</span>
				</div>
				<h3 class="headline-serif-sm">Download Resume</h3>
			</BentoCard>

		</div>
	</main>
</Layout>

<style>
	.connect-card {
		padding-top: 1.5rem;
	}

	.connect-title {
		color: white;
		opacity: 0.8;
		margin-bottom: 1.5rem;
	}

	.social-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.social-link {
		text-decoration: none;
	}

	.social-icon {
		width: 5rem;
		height: 5rem;
		background-color: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: var(--radius-inner);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s ease-in-out;
		color: white;
	}

	.social-link:hover .social-icon {
		background-color: rgba(255, 255, 255, 0.15);
		border-color: rgba(255, 255, 255, 0.3);
		transform: translateY(-2px);
	}

	.social-icon svg {
		width: 1.375rem;
		height: 1.375rem;
	}

	.brand-title {
		font-family: var(--font-headline);
		font-size: 4rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.1;
		color: var(--color-primary);
	}

	.headline-serif {
		font-family: var(--font-headline);
		font-size: 2rem;
		font-weight: 600;
		line-height: 1.3;
	}

	.headline-serif-sm {
		font-family: var(--font-headline);
		font-size: 1.5rem;
		font-weight: 600;
	}

	.icon-circle-outline {
		width: 4rem;
		height: 4rem;
		background-color: rgba(255, 255, 255, 0.2);
		border-radius: var(--radius-pill);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.body-lg {
		font-size: 1.125rem;
		color: var(--color-on-surface-variant);
	}

	/* Tablet Fixes */
	@media (max-width: 1024px) {
		.bento-grid {
			grid-template-columns: repeat(6, 1fr);
		}
		.span-4 { grid-column: span 3; }
		.span-8 { grid-column: span 6; }
		.span-3 { grid-column: span 3; }
		.span-6 { grid-column: span 6; }
	}

	@media (max-width: 768px) {
		.bento-grid {
			grid-template-columns: 1fr;
		}
		.brand-title {
			font-size: 2.5rem;
		}
	}
</style>