---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Akkshay | Developer Portfolio">
  <main class="w-full max-w-[1600px] mx-auto h-screen border-x border-white/10 relative bg-[#0a0a0a] flex flex-col overflow-y-auto overflow-x-hidden">
    <div class="p-6 md:p-8 lg:p-10 flex flex-col space-y-12 md:space-y-16">
      <header class="flex flex-col space-y-8">
        <div>
          <h1 class="text-4xl md:text-5xl lg:text-7xl font-light mb-6 tracking-tight">Hi, I'm Akkshay</h1>
          <div class="border border-white/10 p-5 md:p-8 bg-white/[0.02] max-w-2xl" data-purpose="bio-container">
            <p class="text-base md:text-xl font-light leading-relaxed text-zinc-400 font-body">
              A developer focused on crafting clean, performant, and aesthetic digital experiences. Specializing in minimal design systems and robust backend architectures.
            </p>
          </div>
        </div>
        <div class="flex flex-wrap gap-4" data-purpose="social-links">
          <a class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition-all duration-300 group" href="#" title="GitHub">
            <i class="fa-brands fa-github text-lg"></i>
          </a>
          <a class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition-all duration-300 group" href="#" title="LinkedIn">
            <i class="fa-brands fa-linkedin-in text-lg"></i>
          </a>
          <a class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition-all duration-300 group" href="#" title="Mail">
            <i class="fa-regular fa-envelope text-lg"></i>
          </a>
        </div>
      </header>

      <section class="flex flex-col" id="projects-section">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-[1px] bg-white/10 flex-grow"></div>
          <h2 class="text-[10px] tracking-[0.5em] font-mono font-light uppercase text-zinc-500">PROJECTS</h2>
          <div class="h-[1px] bg-white/10 flex-grow"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="relative group aspect-[4/3] border border-white/10 overflow-hidden hover-lift bg-zinc-900" data-purpose="project-card">
            <img alt="Aura Archive" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-70" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAAhHpGlvOuoT5tDq25BOaGS802tplE-jZ-DlHhXkl7lntvh4bK7thPhwap8sGnJPom1999TydLyewbL1icArKJYjj7e79OsMRjxdnc646w1QIVKxyeI0bkIVEaBm4CgJcJGkjcM23-0Q5YN_ePiIOps8Ajjcz7xHiaNOmzXtdiSjIAEM4xvRQYRY3qOsQQKavADBzd9l8DU9AUm9PsBAJd_igW4J6KakGgqxgdC-M5xolsTTfnnHPB9aK07QcrNlYYpdxDny2FmaEv"/>
            <div class="absolute bottom-0 left-0 right-0 p-5 frosted-glass flex flex-col justify-end translate-y-1 group-hover:translate-y-0 transition-transform duration-500">
              <h3 class="text-[10px] font-mono tracking-[0.2em] uppercase mb-2 text-white">AURA ARCHIVE</h3>
              <p class="font-display italic text-sm text-white/80 leading-snug">Minimalist CMS built for creative portfolios.</p>
            </div>
          </div>
          <div class="relative group aspect-[4/3] border border-white/10 overflow-hidden hover-lift bg-zinc-900" data-purpose="project-card">
            <img alt="Nexus API" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-70" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAutSPW7nAfRsP8ze9xvkkK_R9ZC_BqOVjnuAYyT6Dolm-9kkSV277VcTtIfS9xsThvCrxcJrEg_tPFVgQyBTgCsp26e76GgVamL8Ank5Ug3cR8m7jBZH_Uo3qcGpQYvAEFCfjyEa-IoeBvVTP4sbuS2UtIy54Iag-7i4I8MGxmcGybqCcZR_sTaJk3jGQMqdN-H7PI1hWXYexeVgDe16Wl6Pdm6ewL_2yXzXwLwO-PzOkCsqWiRfU0FGe3P7NfkdZbHpq2PuDAdNrk"/>
            <div class="absolute bottom-0 left-0 right-0 p-5 frosted-glass flex flex-col justify-end translate-y-1 group-hover:translate-y-0 transition-transform duration-500">
              <h3 class="text-[10px] font-mono tracking-[0.2em] uppercase mb-2 text-white">NEXUS API</h3>
              <p class="font-display italic text-sm text-white/80 leading-snug">Distributed GraphQL engine for edge sync.</p>
            </div>
          </div>
          <div class="relative group aspect-[4/3] border border-white/10 overflow-hidden hover-lift bg-zinc-900" data-purpose="project-card">
            <img alt="Void Canvas" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-70" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC8mivUh3TKOYbaJadUlug2zFTHS1kfNoA3EMhKkRUpYnGINs5hupYEvFZDdW6ypz7zwncLLeGdFeVJJ5aDXTHcFjDGWA8wvJC9gsVH9bojtEoQr6LYBtzKxr3X2dLXaZSgbg6KXceKbYbClzWYcuyAZ20sQdbe-Kb7CFmk1ILc9VvfA1akohz2PeETOYbNL6QnjHME_sSgwwMuxrRM-w_dzmnLKXQsLaRGCwP_D5LfzDv_eQUaLTenXoCRjgqNbGgKzSyQz5dQulDh"/>
            <div class="absolute bottom-0 left-0 right-0 p-5 frosted-glass flex flex-col justify-end translate-y-1 group-hover:translate-y-0 transition-transform duration-500">
              <h3 class="text-[10px] font-mono tracking-[0.2em] uppercase mb-2 text-white">VOID CANVAS</h3>
              <p class="font-display italic text-sm text-white/80 leading-snug">WebGL app for complex procedural textures.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="flex flex-col pb-12" id="articles-section">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-[1px] bg-white/10 flex-grow"></div>
          <h2 class="text-[10px] tracking-[0.5em] font-mono font-light uppercase text-zinc-500">ARTICLES</h2>
          <div class="h-[1px] bg-white/10 flex-grow"></div>
        </div>
        <div class="max-w-4xl mx-auto w-full space-y-px bg-white/10 border border-white/10 overflow-hidden">
          <a class="group flex items-center justify-between p-6 bg-[#0a0a0a] hover:bg-white/[0.03] transition-colors" href="#">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">Oct 2023</span>
              <h3 class="font-display text-xl text-zinc-300 group-hover:text-white transition-colors">The Aesthetic of Minimal Code</h3>
            </div>
            <i class="fa-solid fa-arrow-right-long text-zinc-600 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
          </a>
          <a class="group flex items-center justify-between p-6 bg-[#0a0a0a] hover:bg-white/[0.03] transition-colors" href="#">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">Sep 2023</span>
              <h3 class="font-display text-xl text-zinc-300 group-hover:text-white transition-colors">Distributed Systems for Solo Devs</h3>
            </div>
            <i class="fa-solid fa-arrow-right-long text-zinc-600 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
          </a>
          <a class="group flex items-center justify-between p-6 bg-[#0a0a0a] hover:bg-white/[0.03] transition-colors" href="#">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">Aug 2023</span>
              <h3 class="font-display text-xl text-zinc-300 group-hover:text-white transition-colors">Building the Obsidian Archive</h3>
            </div>
            <i class="fa-solid fa-arrow-right-long text-zinc-600 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
          </a>
        </div>
        <div class="mt-8 text-center">
          <a class="text-[10px] font-mono text-zinc-500 uppercase tracking-[0.3em] hover:text-white transition-colors" href="#">Read All Articles</a>
        </div>
      </section>
    </div>
  </main>
</Layout>