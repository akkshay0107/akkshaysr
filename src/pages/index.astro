---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleItem from '../components/ArticleItem.astro';
import SocialButton from '../components/SocialButton.astro';
import { getArticles } from '../utils/articles';

const articles = (await getArticles())
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="akkshay's website">
  <main class="w-full max-w-[1600px] mx-auto min-h-screen border-x border-white/10 relative bg-[#0a0a0a] flex flex-col">
    <div class="p-6 md:p-8 lg:p-10 flex flex-col space-y-12 md:space-y-16">
      <header class="flex flex-col space-y-8">
        <div>
          <h1 class="text-4xl md:text-5xl lg:text-7xl font-light mb-6 tracking-tight">Hi, I'm Akkshay</h1>
          <div class="border border-white/10 p-5 md:p-8 bg-white/[0.02] max-w-2xl" data-purpose="bio-container">
            <p class="text-base md:text-xl font-light leading-relaxed text-zinc-400 font-body">
              A developer focused on crafting clean, performant, and aesthetic digital experiences. Specializing in minimal design systems and robust backend architectures.
            </p>
          </div>
        </div>
        <div class="flex flex-wrap gap-4" data-purpose="social-links">
          <SocialButton href="https://github.com/akkshay0107" title="GitHub" iconClass="fa-brands fa-github" />
          <SocialButton href="https://linkedin.com/in/akkshaysr" title="LinkedIn" iconClass="fa-brands fa-linkedin-in" />
          <SocialButton href="mailto:akkshaysr0107@gmail.com" title="Mail" iconClass="fa-regular fa-envelope" />
        </div>
      </header>

      <section class="flex flex-col" id="projects-section">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-[1px] bg-white/10 flex-grow"></div>
          <h2 class="text-[10px] tracking-[0.5em] font-mono font-light uppercase text-zinc-500">PROJECTS</h2>
          <div class="h-[1px] bg-white/10 flex-grow"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <ProjectCard
            title="AURA ARCHIVE"
            description="Minimalist CMS built for creative portfolios."
            image="https://lh3.googleusercontent.com/aida-public/AB6AXuAAhHpGlvOuoT5tDq25BOaGS802tplE-jZ-DlHhXkl7lntvh4bK7thPhwap8sGnJPom1999TydLyewbL1icArKJYjj7e79OsMRjxdnc646w1QIVKxyeI0bkIVEaBm4CgJcJGkjcM23-0Q5YN_ePiIOps8Ajjcz7xHiaNOmzXtdiSjIAEM4xvRQYRY3qOsQQKavADBzd9l8DU9AUm9PsBAJd_igW4J6KakGgqxgdC-M5xolsTTfnnHPB9aK07QcrNlYYpdxDny2FmaEv"
            alt="Aura Archive"
          />
          <ProjectCard
            title="NEXUS API"
            description="Distributed GraphQL engine for edge sync."
            image="https://lh3.googleusercontent.com/aida-public/AB6AXuAutSPW7nAfRsP8ze9xvkkK_R9ZC_BqOVjnuAYyT6Dolm-9kkSV277VcTtIfS9xsThvCrxcJrEg_tPFVgQyBTgCsp26e76GgVamL8Ank5Ug3cR8m7jBZH_Uo3qcGpQYvAEFCfjyEa-IoeBvVTP4sbuS2UtIy54Iag-7i4I8MGxmcGybqCcZR_sTaJk3jGQMqdN-H7PI1hWXYexeVgDe16Wl6Pdm6ewL_2yXzXwLwO-PzOkCsqWiRfU0FGe3P7NfkdZbHpq2PuDAdNrk"
            alt="Nexus API"
          />
          <ProjectCard
            title="VOID CANVAS"
            description="WebGL app for complex procedural textures."
            image="https://lh3.googleusercontent.com/aida-public/AB6AXuC8mivUh3TKOYbaJadUlug2zFTHS1kfNoA3EMhKkRUpYnGINs5hupYEvFZDdW6ypz7zwncLLeGdFeVJJ5aDXTHcFjDGWA8wvJC9gsVH9bojtEoQr6LYBtzKxr3X2dLXaZSgbg6KXceKbYbClzWYcuyAZ20sQdbe-Kb7CFmk1ILc9VvfA1akohz2PeETOYbNL6QnjHME_sSgwwMuxrRM-w_dzmnLKXQsLaRGCwP_D5LfzDv_eQUaLTenXoCRjgqNbGgKzSyQz5dQulDh"
            alt="Void Canvas"
          />
        </div>
      </section>

      <section class="flex flex-col pb-12" id="articles-section">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-[1px] bg-white/10 flex-grow"></div>
          <h2 class="text-[10px] tracking-[0.5em] font-mono font-light uppercase text-zinc-500">ARTICLES</h2>
          <div class="h-[1px] bg-white/10 flex-grow"></div>
        </div>
        <div class="max-w-4xl mx-auto w-full space-y-px bg-white/10 border border-white/10 overflow-hidden">
          {articles.map((article) => (
            <ArticleItem article={article} />
          ))}
          {articles.length === 0 && (
            <div class="p-12 text-center bg-[#0a0a0a]">
              <p class="text-zinc-500 font-mono text-[10px] uppercase tracking-widest">No articles found</p>
            </div>
          )}
        </div>

      </section>
    </div>
  </main>
</Layout>