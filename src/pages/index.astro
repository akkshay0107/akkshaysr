---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectCarousel from '../components/ProjectCarousel.astro';
import ArticleItem from '../components/ArticleItem.astro';
import { getArticles } from '../utils/articles';
import { projects } from '../data/projects';

const articles = (await getArticles())
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const projectsCount = String(projects.length).padStart(2, '0');
const articlesCount = String(articles.length).padStart(2, '0');
---

<Layout title="akkshay's website">
  <main id="home" data-screen-label="Home">
    <section class="hero wrap">
      <div class="hero-main">
        <h1>Hi, I’m Akkshay</h1>
        <p class="lede">I'm a sophomore at <b>Purdue University</b> studying <b>CS</b> and <b>Math</b>. Lately, most of my work has been focused on <b>reinforcement learning, AI agents and building transformer models</b>. I'm also interested in competitive programming and training language models. Feel free to reach out if you'd like to connect or have any queries. </p>
      </div>

      <aside class="rail">
        <div class="rail-group">
          <div class="eyebrow">Elsewhere</div>
          <ul class="rail-list">
            <li>
              <a class="rail-link" href="https://github.com/akkshay0107" target="_blank" rel="noopener noreferrer">
                GitHub <span class="arr">↗</span>
              </a>
            </li>
            <li>
              <a class="rail-link" href="https://linkedin.com/in/akkshaysr" target="_blank" rel="noopener noreferrer">
                LinkedIn <span class="arr">↗</span>
              </a>
            </li>
            <li>
              <a class="rail-link" href="mailto:akkshaysr0107@gmail.com">
                Email <span class="arr">↗</span>
              </a>
            </li>
          </ul>
        </div>

        <div class="rail-group">
          <div class="eyebrow">Resume</div>
          <ul class="rail-list">
            <li>
              <a class="rail-link" href="/resume.pdf" target="_blank" rel="noopener noreferrer">
                View PDF <span class="arr">↗</span>
              </a>
            </li>
          </ul>
        </div>
      </aside>
    </section>

    <section class="section projects wrap" id="projects">
      <div class="section-head">
        <span class="label">Things I've Built</span>
        <span class="count">{projectsCount}</span>
        <span class="rule"></span>
      </div>
      <ProjectCarousel>
        {projects.map((project, index) => (
          <div class="w-full md:w-[calc(33.333%-16px)] flex-shrink-0">
            <ProjectCard
              {...project}
              monogram={String(index + 1).padStart(2, '0')}
            />
          </div>
        ))}
      </ProjectCarousel>
    </section>

    <section class="section writing wrap" id="writing">
      <div class="section-head">
        <span class="label">Articles</span>
        <span class="count">{articlesCount}</span>
        <span class="rule"></span>
      </div>
      <div class="post-list">
        {articles.map((article) => (
          <ArticleItem article={article} />
        ))}
        {articles.length === 0 && (
          <div class="p-12 text-center bg-[var(--bg-panel)] border border-[var(--line-soft)] rounded">
            <p class="text-zinc-500 font-mono text-[10px] uppercase tracking-widest">No articles found</p>
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>
