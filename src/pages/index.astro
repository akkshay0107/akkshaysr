---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectCarousel from '../components/ProjectCarousel.astro';
import ArticleItem from '../components/ArticleItem.astro';
import SocialButton from '../components/SocialButton.astro';
import { getArticles } from '../utils/articles';
import { projects } from '../data/projects';

const articles = (await getArticles())
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="akkshay's website">
  <main class="w-full max-w-[1600px] mx-auto min-h-screen border-x border-white/10 relative flex flex-col">
    <div class="p-6 md:p-8 lg:p-10 flex flex-col space-y-12 md:space-y-16">
      <header class="flex flex-col space-y-8">
        <div>
          <h1 class="text-4xl md:text-5xl lg:text-7xl font-light mb-6 tracking-tight animate-tracking-in">Hi, I'm Akkshay</h1>
          <div class="border border-white/10 p-5 md:p-8 bg-white/[0.02] max-w-2xl" data-purpose="bio-container">
            <p class="text-base md:text-xl font-light leading-relaxed text-zinc-400 font-body">
              A researcher and developer focused on high-performance systems and machine learning. Building reinforcement learning engines, multimodal search tools, and robust architectures in Rust and TypeScript.
            </p>
          </div>
        </div>
        <div class="flex flex-wrap gap-4" data-purpose="social-links">
          <SocialButton href="https://github.com/akkshay0107" title="GitHub" iconClass="fa-brands fa-github" />
          <SocialButton href="https://linkedin.com/in/akkshaysr" title="LinkedIn" iconClass="fa-brands fa-linkedin-in" />
          <SocialButton href="mailto:akkshaysr0107@gmail.com" title="Mail" iconClass="fa-regular fa-envelope" />
        </div>
      </header>

      <section class="flex flex-col" id="projects-section">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-[1px] bg-white/10 flex-grow"></div>
          <h2 class="text-[10px] tracking-[0.5em] font-mono font-light uppercase text-zinc-500">PROJECTS</h2>
          <div class="h-[1px] bg-white/10 flex-grow"></div>
        </div>
        <ProjectCarousel>
          {projects.map((project) => (
            <div class="w-full md:w-[calc(33.333%-16px)] flex-shrink-0">
              <ProjectCard {...project} />
            </div>
          ))}
        </ProjectCarousel>
      </section>

      <section class="flex flex-col pb-12" id="articles-section">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-[1px] bg-white/10 flex-grow"></div>
          <h2 class="text-[10px] tracking-[0.5em] font-mono font-light uppercase text-zinc-500">ARTICLES</h2>
          <div class="h-[1px] bg-white/10 flex-grow"></div>
        </div>
        <div class="max-w-4xl mx-auto w-full space-y-px bg-white/10 border border-white/10 overflow-hidden">
          {articles.map((article) => (
            <ArticleItem article={article} />
          ))}
          {articles.length === 0 && (
            <div class="p-12 text-center bg-[#0a0a0a]">
              <p class="text-zinc-500 font-mono text-[10px] uppercase tracking-widest">No articles found</p>
            </div>
          )}
        </div>

      </section>
    </div>
  </main>
</Layout>
