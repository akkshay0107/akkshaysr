---

<div class="relative group" id="project-carousel-container">
  <!-- Navigation Buttons -->
  <button
    id="prev-btn"
    class="carousel-btn prev"
    aria-label="Previous projects"
  >
    <i class="fa-solid fa-chevron-left"></i>
  </button>

  <button
    id="next-btn"
    class="carousel-btn next"
    aria-label="Next projects"
  >
    <i class="fa-solid fa-chevron-right"></i>
  </button>

  <!-- Carousel Track -->
  <div
    id="carousel-track"
    class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar"
  >
    <slot />
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  #carousel-track {
    padding-bottom: 28px;
    margin-bottom: -28px;
  }

  /* Redesigned navigation buttons using design tokens */
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in oklch, var(--bg-panel) 60%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--fg-dim);
    border: 1px solid var(--line-soft);
    border-radius: 4px;
    opacity: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .carousel-btn.prev {
    left: 16px;
  }

  .carousel-btn.next {
    right: 16px;
  }

  .carousel-btn:hover {
    color: var(--fg);
    border-color: var(--line);
    background: color-mix(in oklch, var(--bg-panel-2) 80%, transparent);
  }

  #project-carousel-container:hover .carousel-btn {
    opacity: 1;
  }

  .carousel-btn:disabled {
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement | null;

  if (track && prevBtn && nextBtn) {
    const getScrollAmount = () => {
      // Scroll by the width of the container
      return track.clientWidth + 24; // width + gap
    };

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    // Hide/disable buttons if at start or end
    const updateButtons = () => {
      const isAtStart = track.scrollLeft <= 0;
      const isAtEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10;

      prevBtn.disabled = isAtStart;
      nextBtn.disabled = isAtEnd;
    };

    track.addEventListener('scroll', updateButtons);
    window.addEventListener('resize', updateButtons);

    // Initial check
    setTimeout(updateButtons, 100);
  }
</script>
