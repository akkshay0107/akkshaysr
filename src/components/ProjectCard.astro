---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  alt: string;
  tags: string[];
  monogram: string;
  bio?: string;
  github?: string;
  demo?: string;
}

const { title, description, image, alt, tags, monogram, bio, github, demo } = Astro.props;
const dialogId = `dialog-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`;
const formattedTags = tags.join(' · ');
---

<div
  class="card"
  data-purpose="project-card"
  onclick={`document.getElementById('${dialogId}').showModal()`}
  role="button"
  tabindex="0"
  aria-label={`View details for ${title}`}
  onkeydown={`if(event.key === 'Enter' || event.key === ' ') { event.preventDefault(); document.getElementById('${dialogId}').showModal(); }`}
>
  <div class="card-thumb">
    <span class="monogram">{monogram}</span>
    <Image 
      alt={alt} 
      src={image} 
      loading="eager" 
      class="project-card-image" 
    />
  </div>
  <div class="card-body">
    <div class="row">
      <span class="name">{title}</span>
    </div>
    <p class="desc">{description}</p>
  </div>
  <span class="card-tag">{formattedTags}</span>
</div>

<dialog id={dialogId} aria-labelledby={`${dialogId}-title`} class="project-dialog">
  <div class="dialog-container">
    <button aria-label="Close project details" class="dialog-close" onclick={`document.getElementById('${dialogId}').close()`}>
      <i class="fa-solid fa-xmark" aria-hidden="true"></i>
    </button>

    <div class="dialog-image-wrapper">
      <Image 
        alt={alt} 
        src={image} 
        loading="lazy" 
        decoding="async" 
      />
      <div class="dialog-image-overlay"></div>
    </div>

    <div class="dialog-body">
       <h3 id={`${dialogId}-title`}>{title}</h3>

       <div class="dialog-text">
         <p>{bio || description}</p>
       </div>

       <div class="dialog-footer">
         {github && (
           <a href={github} target="_blank" rel="noopener noreferrer" class="dialog-btn dialog-btn-primary">
             <i class="fa-brands fa-github text-sm"></i> GitHub
           </a>
         )}
         {demo && demo !== '#' && (
           <a href={demo} target="_blank" rel="noopener noreferrer" class="dialog-btn dialog-btn-secondary">
             <i class="fa-solid fa-arrow-up-right-from-square text-sm"></i> Live Demo
           </a>
         )}
       </div>
    </div>
  </div>
</dialog>

<script>
  document.querySelectorAll('dialog').forEach((dialog) => {
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  });
</script>
