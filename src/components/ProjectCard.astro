---
interface Props {
  title: string;
  description: string;
  image: string;
  alt: string;
}

const { title, description, image, alt } = Astro.props;
---

<div class="relative group aspect-[4/3] border border-white/10 overflow-hidden hover-lift bg-zinc-900" data-purpose="project-card">
  <img alt={alt} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-70" src={image} />
  <div class="absolute bottom-0 left-0 right-0 p-6 pt-12 frosted-glass flex flex-col justify-end translate-y-1 group-hover:translate-y-0 transition-transform duration-500">
    <h3 class="text-[10px] font-mono tracking-[0.2em] uppercase mb-2 text-white">{title}</h3>
    <p class="font-body text-sm text-white/90 leading-relaxed">{description}</p>
  </div>
</div>
