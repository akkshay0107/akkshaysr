---
import type { ArticleData } from '../utils/articles';

interface Props {
  article: {
    slug: string;
    data: ArticleData;
  };
}

const { article } = Astro.props;
const { title, date, category = 'Essays' } = article.data;
const href = `/articles/${article.slug}`;

const formattedDate = date.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});
---

<a class="post-row" href={href}>
  <span class="date">{formattedDate}</span>
  <span class="title">{title}</span>
  <span class="meta-cat">{category} <span class="arr">&rarr;</span></span>
</a>
